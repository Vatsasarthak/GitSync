{
  "manifest_version": 3,
  "name": "GFG Sync",
  "key": "",
  "version": "1.1.0",
  "description": "Automatically sync your GeeksforGeeks solutions to a GitHub repository.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "*://*.geeksforgeeks.org/*",
    "https://gfgsync.onrender.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://practice.geeksforgeeks.org/*",
        "*://www.geeksforgeeks.org/problems/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
